{
	"schemaVersion": 1,
	"id": "pocketdimensions",
	"version": "${version}",
	"name": "Pocket Dimensions",
	"description": "A mod that adds simple, customizable pocket dimensions that can be accessed from anywhere.",
	"authors": [
		"Nimbu"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/NimbuMC/Fabric-Pocket-Dimensions-1.21"
	},
	"license": "CC0-1.0",
	"icon": "assets/pocketdimensions/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.nimbu.pocketdimensions.PocketDimensions"
		],
		"fabric-datagen": [
			"net.nimbu.pocketdimensions.PocketDimensionsDataGenerator"
		],
		"client": [
			"net.nimbu.pocketdimensions.PocketDimensionsClient"
		],
		"cardinal-components-entity": [
			"net.nimbu.pocketdimensions.component.ModComponentInitializer"
		]
	},
	"mixins": [
		"pocketdimensions.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.16.14",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-key-binding-api-v1": "*",
		"cardinal-components-base": "*",
		"cardinal-components-entity": ">=6.1.0",
		"dimlib": ">=1.1.0"
	},
	"custom": {
		"cardinal-components": [
			"pocketdimensions:player_gateway"
		]
	}
}